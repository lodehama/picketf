<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="EtfMapper">

  <!-- 특정 코드의 TER 조회 (etf_ter DB 연동을 위해 만듦) -->
  <select id="selectEtfRealCostByCode" parameterType="string" resultType="double">
    SELECT etf_real_cost
    FROM etf
    WHERE etf_code = #{code}
  </select>

</mapper>
