<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hama.picketf.dao.SubsDAO">

  <!-- 이렇게 안 하면 뭘해도 에러 발생 -->
  <!-- ====================== 공통 resultMap ====================== -->
  <resultMap id="SubsResultMap" type="com.hama.picketf.dto.SubsDTO">
    <id     column="subs_num"         property="subsNum" />
    <result column="subs_us_num"      property="subsUsNum" />
    <result column="subs_name"        property="subsName" />
    <result column="subs_price"       property="subsPrice" />
    <result column="subs_type"        property="subsType" />
    <result column="subs_billing_day" property="subsBillingDay" />
    <result column="subs_active"      property="subsActive" />
    <result column="subs_start_date"  property="subsStartDate" />
    <result column="subs_icon"        property="subsIcon" />
  </resultMap>

  <!-- ====================== INSERT ====================== -->
  <insert id="insertSubs"
          parameterType="com.hama.picketf.dto.SubsDTO"
          useGeneratedKeys="true"
          keyProperty="subsNum">
    INSERT INTO subs (
      subs_us_num,
      subs_name,
      subs_price,
      subs_type,
      subs_billing_day,
      subs_active,
      subs_start_date,
      subs_icon
    ) VALUES (
      #{subsUsNum},
      #{subsName},
      #{subsPrice},
      #{subsType},
      #{subsBillingDay},
      #{subsActive},
      #{subsStartDate},
      #{subsIcon}
    )
  </insert>

  <insert id="insertSubsList" parameterType="java.util.List">
    INSERT INTO subs (
      subs_us_num,
      subs_name,
      subs_price,
      subs_type,
      subs_billing_day,
      subs_active,
      subs_start_date,
      subs_icon
    )
    VALUES
    <foreach collection="list" item="s" separator=",">
      (
        #{s.subsUsNum},
        #{s.subsName},
        #{s.subsPrice},
        #{s.subsType},
        #{s.subsBillingDay},
        #{s.subsActive},
        #{s.subsStartDate},
        #{s.subsIcon}
      )
    </foreach>
  </insert>

  <!-- ====================== SELECT ====================== -->
  <select id="getSubsListByUser"
          parameterType="long"
          resultMap="SubsResultMap">
    SELECT
      subs_num,
      subs_us_num,
      subs_name,
      subs_price,
      subs_type,
      subs_billing_day,
      subs_active,
      subs_start_date,
      subs_icon
    FROM subs
    WHERE subs_us_num = #{userNum}
    ORDER BY subs_billing_day, subs_num
  </select>

</mapper>
